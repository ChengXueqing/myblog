# 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============== 企业微信群机器人 ==============
# 企微群机器人 webhook URL（接收消息模式）
WECOM_BOT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# ============== LLM API (DeepSeek / 硅基流动) ==============
# DeepSeek API
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-chat

# 硅基流动 API (备选)
# LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=deepseek-ai/DeepSeek-V2.5

# ============== GitHub ==============
# GitHub Personal Access Token (需要 repo 权限)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 博客仓库 (格式: username/repo)
GITHUB_REPO=ChengXueqing/myblog
GITHUB_BRANCH=master
